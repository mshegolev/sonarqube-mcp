# SonarQube base URL (no trailing slash).
#   Examples:
#   - SaaS:         https://sonarcloud.io
#   - Self-hosted:  https://sonar.example.com
#   - On-prem:      https://sonar.internal.corp
SONARQUBE_URL=https://sonar.example.com

# SonarQube authentication token (Bearer).
# Generate in: My Account → Security → Tokens.
# Either a "User" or a "Project Analysis" token works for read-only tools.
SONARQUBE_TOKEN=squ_abcdef0123456789

# Verify SSL certificates. Set to "false" for self-signed certs.
# Default: "true". Accepts: true/false/1/0/yes/no.
SONARQUBE_SSL_VERIFY=true
